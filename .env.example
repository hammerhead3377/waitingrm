# ─── Telegram ────────────────────────────────────────────────────────────────
# Bot token from @BotFather
BOT_TOKEN=your_bot_token_here

# Comma-separated Telegram user IDs allowed access (get yours from @userinfobot)
ALLOWED_USER_IDS=123456789

# HTTPS URL where index.html is hosted (Telegram requires HTTPS for Mini Apps)
# Option A: deploy nginx/www/index.html to Cloudflare Pages / Vercel
# Option B: use a real domain pointed at your LAN with a trusted TLS cert
MINI_APP_URL=https://your-app.pages.dev

# ─── Network ─────────────────────────────────────────────────────────────────
# LAN IP of this manager node — used to bind Nginx ports and for the TLS SAN
LAN_IP=192.168.1.100
